# IOTA RPC / package
IOTA_NODE_URL=https://api.devnet.iota.cafe
IOTA_PACKAGE_ID=0x52bcff89c205d8f8b0ec62294f1baf7d6c9f52cce6437849d68d8557b6f7ed44
# PackageMetadataV1 object ID — required for AA governance
IOTA_PACKAGE_METADATA_ID=0x4231e7cab5f8e276c0d2bb61c72bf2ab59ebf2903f58a38aaf885a6cf52678dd

# Server runtime
NOTARIZATION_BIND_ADDR=0.0.0.0:8080
NOTARIZATION_PROFILE=devnet
NOTARIZATION_LAUNCH_MODE=dry_run
STARTUP_CHECKS_ENABLED=true

# Public verify limits / payload protection
MAX_PAYLOAD_BYTES=4096
VERIFY_RATE_LIMIT_PER_MINUTE=60

# Admin / role controls
NOTARIZATION_ADMIN_LOCAL_ONLY=true
NOTARIZATION_ADMIN_API_KEY=
ROLE_VERIFIER_API_KEY=
ROLE_POLICY_ADMIN_API_KEY=
ROLE_ONBOARDING_ADMIN_API_KEY=

# JSON persistence stores
TRUST_POLICY_PATH=trust_policy.json
POLICY_GOVERNANCE_PATH=policy_governance.json
ONBOARDING_STORE_PATH=onboarding_store.json
COMPLIANCE_STORE_PATH=compliance_store.json

# Cache / observability
VERIFY_CACHE_TTL_SECONDS=60
METADATA_INDEX_TTL_SECONDS=120
SYNTHETIC_CHECK_ENABLED=false
SYNTHETIC_CHECK_INTERVAL_SECONDS=60
SYNTHETIC_NOTARIZATION_ID=
SYNTHETIC_PAYLOAD=
AUDIT_RETENTION_DAYS=90
LOG_RETENTION_DAYS=30

# Optional secret file path (ROLE_* keys fallback)
SECRETS_FILE_PATH=

# Comma-separated allowlists used only by verifier policy.
# Empty value means no filter on that dimension.
TRUST_ACCEPTED_DOMAINS=did:iota:domain:scuola-guida-milano
TRUST_ACCEPTED_ISSUERS=did:iota:issuer:autoscuola-rossi
TRUST_ACCEPTED_TEMPLATE_VERSIONS=1,2
TRUST_BLOCKED_ISSUERS=
