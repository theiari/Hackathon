# Frontend API target (Axum backend)
VITE_NOTARIZATION_API_URL=http://127.0.0.1:8080
# Default wallet network shown in app header
VITE_IOTA_DEFAULT_NETWORK=devnet
# RPC URLs by network
VITE_IOTA_DEVNET_RPC_URL=https://api.devnet.iota.cafe
VITE_IOTA_TESTNET_RPC_URL=
VITE_IOTA_MAINNET_RPC_URL=
# Move package IDs by network
# ⚠ UPDATE AFTER REDEPLOY: run the following, then paste the new package ID here
# cd move/counter && iota client publish --gas-budget 100000000
VITE_IOTA_DEVNET_PACKAGE_ID=0x52bcff89c205d8f8b0ec62294f1baf7d6c9f52cce6437849d68d8557b6f7ed44
VITE_IOTA_TESTNET_PACKAGE_ID=0xTODO
VITE_IOTA_MAINNET_PACKAGE_ID=0xTODO
# PackageMetadataV1 object ID — required for AA governance
# After redeploy: find in tx effects (type contains "PackageMetadataV1")
VITE_PACKAGE_METADATA_ID=0x4231e7cab5f8e276c0d2bb61c72bf2ab59ebf2903f58a38aaf885a6cf52678dd

# Seed script — required only when running npm run seed:demo with ENABLE_REAL_TX=true
IOTA_SEED_PHRASE=
ENABLE_REAL_TX=false
DEMO_SIGNER_ADDRESS=
ROLE_VERIFIER_API_KEY=abcd
